# --- Web auth (apps/web): Logto SSO, CCL's central IdP ---
# Humans sign in via SSO Logto (auth.coldcodelabs.com). Leave all five LOGTO_*
# vars unset for local dev — the board runs as an open shell (fake "Local"
# admin). Set all five to put real login in front. Scope = human web SSO only;
# this does NOT gate the runner/API (see BROKK_RUNNER_SECRET in the root env).
LOGTO_ENDPOINT=https://auth.coldcodelabs.com
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=http://localhost:3010          # prod: https://brokk.coldcodelabs.com
LOGTO_COOKIE_SECRET=                           # generate: openssl rand -base64 32
