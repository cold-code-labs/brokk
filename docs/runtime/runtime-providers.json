{
 "$comment": "Machine-readable knowledge for the Runtime skill (docs/runtime/SKILL.md). The skill fills command templates from `providers` and MUST satisfy `allowlist`. v2: nextjs, vite, astro are supported:true. Adding a stack = one entry here (+ the trusted mirror in packages/runtime/src/providers.ts).",
 "version": 2,
 "packageManagers": {
  "pnpm": {
   "lockfile": "pnpm-lock.yaml",
   "exec": "pnpm exec",
   "install": "pnpm install --no-frozen-lockfile"
  },
  "npm": {
   "lockfile": "package-lock.json",
   "exec": "npx",
   "install": "npm install"
  },
  "yarn": {
   "lockfile": "yarn.lock",
   "exec": "yarn",
   "install": "yarn install"
  },
  "bun": {
   "lockfile": "bun.lockb",
   "exec": "bunx",
   "install": "bun install"
  }
 },
 "allowlist": {
  "$comment": "Every emitted install/dev/build/start command must match one of these (after $PORT/$HOST substitution). Validation is automatic and replaces human approval.",
  "binaries": [
   "next",
   "vite",
   "astro",
   "node",
   "next-server",
   "expo"
  ],
  "verbs": [
   "install",
   "exec",
   "run",
   "dev",
   "build",
   "start",
   "preview"
  ],
  "patterns": [
   "^(pnpm|npm|yarn|bun)( install| exec| run)?( --[a-z-]+(=[\\w./-]+)?)*( (next|vite|astro|node|npx|bunx))?",
   "(next|vite|astro)( dev| build| start| preview)?( --webpack)?( -p \\$PORT)?( -H 0.0.0.0)?( --port \\$PORT)?( --host 0.0.0.0)?( --config=[\\w./-]+)?",
   "&&"
  ],
  "forbidden": [
   ";",
   "|",
   "`",
   "$(",
   "curl",
   "wget",
   "sudo",
   "chmod",
   "rm ",
   "ssh",
   "eval",
   ">",
   "<"
  ]
 },
 "providers": {
  "nextjs": {
   "label": "Next.js",
   "supported": true,
   "detect": {
    "anyDep": [
     "next"
    ],
    "anyFile": [
     "next.config.js",
     "next.config.mjs",
     "next.config.ts"
    ],
    "anyScriptMatches": "next (dev|build|start)"
   },
   "commands": {
    "install": "{install}",
    "dev": "{exec} next dev -p $PORT -H 0.0.0.0",
    "build": "{exec} next build",
    "start": "{exec} next start -p $PORT -H 0.0.0.0"
   },
   "health": "/",
   "notes": "BROKK-37: never emit --turbo/--turbopack. Turbopack \u22484GB/app (invi\u00e1vel na densifica\u00e7\u00e3o). For Next \u226516 the resolver injects --webpack at boot (~1\u20131.5GB webpack/SWC). Next 15 already defaults to webpack — do not pass --webpack there (unknown option)."
  },
  "vite": {
   "label": "Vite",
   "supported": true,
   "detect": {
    "anyDep": [
     "vite"
    ],
    "anyFile": [
     "vite.config.js",
     "vite.config.ts",
     "vite.config.mjs"
    ],
    "anyScriptMatches": "vite( build| preview)?"
   },
   "commands": {
    "install": "{install}",
    "dev": "{exec} vite --port $PORT --host 0.0.0.0 --config=.brokk/vite.preview.config.mjs",
    "build": "{exec} vite build",
    "start": "{exec} vite preview --port $PORT --host 0.0.0.0 --config=.brokk/vite.preview.config.mjs"
   },
   "prepareFiles": [".brokk/vite.preview.config.mjs"],
   "health": "/"
  },
  "astro": {
   "label": "Astro",
   "supported": true,
   "detect": {
    "anyDep": [
     "astro"
    ],
    "anyFile": [
     "astro.config.mjs",
     "astro.config.ts"
    ],
    "anyScriptMatches": "astro (dev|build|preview)"
   },
   "commands": {
    "install": "{install}",
    "dev": "{exec} astro dev --port $PORT --host 0.0.0.0",
    "build": "{exec} astro build",
    "start": "{exec} astro preview --port $PORT --host 0.0.0.0"
   },
   "health": "/"
  },
  "expo": {
   "label": "Expo (Metro)",
   "supported": true,
   "detect": {
    "anyDep": [
     "expo"
    ],
    "anyFile": [
     "app.config.ts",
     "app.config.js",
     "app.json"
    ],
    "anyScriptMatches": "expo start"
   },
   "commands": {
    "dev": "{exec} expo start --dev-client --port $PORT",
    "build": "{exec} expo export --platform=web",
    "start": "{exec} expo start --dev-client --port $PORT"
   },
   "health": "/status",
   "env": {
    "EXPO_PACKAGER_PROXY_URL": "$PUBLIC_URL",
    "CI": "1"
   },
   "notes": "Divisao mobile (React Native). O preview e o Metro: serve bundle JS pro dev client no aparelho (deep link expo-development-client), nao renderiza HTML. health /status responde 'packager-status:running'."
  }
 }
}
