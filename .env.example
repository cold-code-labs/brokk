# --- Web auth (apps/web): Logto SSO, CCL's central IdP ---
# Humans sign in via SSO Logto (auth.coldcodelabs.com). Leave the five LOGTO_*
# vars unset for local dev — the web board runs as an open shell (fake "Local"
# admin). Set all five to put real login in front. Does NOT gate the runner/API.
LOGTO_ENDPOINT=https://auth.coldcodelabs.com
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=http://localhost:3010          # prod: https://brokk.coldcodelabs.com
LOGTO_COOKIE_SECRET=                           # generate: openssl rand -base64 32

# --- Brokk control plane ---
BROKK_DATABASE_URL=postgres://brokk:brokk@localhost:5432/brokk
BROKK_API_PORT=8789
# Internal API URL for the Next.js web app (Docker: http://api:8789).
BROKK_API_INTERNAL_URL=http://127.0.0.1:8789
# Bearer secret for mutating API calls (POST/PUT/PATCH/DELETE). Set the SAME value
# on the API and the web (the web proxy injects it server-side). Empty = open (dev).
# Reads stay open; /runner & /webhooks self-auth. Generate: openssl rand -hex 32
BROKK_API_SECRET=

# --- Self-host (docker-compose.yml) ---
# POSTGRES_PASSWORD=          # db password (default: brokk)
# BROKK_HTTP_PORT=80          # Traefik public entrypoint port
# BROKK_TRAEFIK_RULE=Host(`brokk.example.com`)   # default: PathPrefix(`/`) (catch-all)

# --- Auto Brokk (Regin overnight intake, BROKK-44) ---
# When BROKK_AUTO=1 the API wraps orphaned recent-failed cards into autoApprove
# missions (one per tick). Caps keep overnight runs from stampeding the shared
# LiteLLM seat / surtr host (2026-07-20 Hostinger throttle lesson):
#   BROKK_AUTO_MAX_LIVE  max planning+running auto-brokk missions (default 1)
#   BROKK_AUTO_PAUSE_MS  cooldown after Mímir 429/529 before intake resumes (default 30m)
# BROKK_AUTO=0
# BROKK_AUTO_MAX_LIVE=1
# BROKK_AUTO_PAUSE_MS=1800000

# --- Runner ↔ control-plane ---
# Shared secret the runner presents on /runner/* endpoints.
BROKK_RUNNER_SECRET=
# Where the runner reaches the control plane (claim / events / complete).
BROKK_CONTROL_URL=http://localhost:8789

# --- Preview access gate ---
# HMAC key for preview access. The web mints keys at /preview-gate/<sub> behind
# the Logto session; the preview-proxy verifies them and trades them for a
# cookie. SET THE SAME VALUE ON BOTH — they are the two halves of one contract,
# and a mismatch 403s every preview.
# UNSET = CLOSED: the proxy refuses every request. That is deliberate. Previews
# serve the app's working tree (uncommitted, with BROKK_LIVE_PREVIEW=1), so a
# gate that silently vanished when someone cleared an env would be worse than no
# gate — everyone would believe it was there.
BROKK_PREVIEW_KEY=
# Zone the previews live under; the web builds the redirect target from it.
BROKK_PREVIEW_DOMAIN=preview.coldcodelabs.com

# --- GitHub webhooks (control plane) ---
# HMAC secret from GitHub → Settings → Webhooks. POST /api/webhooks/github
# moves merged PRs from Review → Done. Empty = skip signature check (dev only).
BROKK_GITHUB_WEBHOOK_SECRET=

# --- GitHub (runner) ---
# Fine-grained token: contents + pull_requests write on target repos. Used by `gh`.
GITHUB_TOKEN=

# --- Default repo/branch (runner) ---
# BROKK_DEFAULT_REPO: owner/repo used when a card doesn't name one.
BROKK_DEFAULT_REPO=
# BROKK_DEFAULT_BRANCH: the GIT BASE branch forge targets for worktrees/PRs
# (apps/forge/src/index.ts falls back to "main" when unset). Do NOT set this to
# "dev" — that string is Brokk's own internal dev-lane/preview branch name used
# throughout forge/chat, a completely different concept. Setting
# BROKK_DEFAULT_BRANCH=dev here points the runner's base branch at the dev lane
# and broke the overnight run. Leave empty (defaults to main) or set explicitly
# to "main".
BROKK_DEFAULT_BRANCH=main

# --- Claude Agent SDK (runner brain) ---
ANTHROPIC_API_KEY=
# Point the SDK at the headroom compression proxy (or the CCL AI gateway).
ANTHROPIC_BASE_URL=http://localhost:8787

# --- Gateway mode (Ratatoskr / LiteLLM) ---
# Set ANTHROPIC_AUTH_TOKEN to a per-tool LiteLLM virtual key to route the runner,
# eitri and Mímir through the shared subscription seat via the gateway. When set,
# the SDK/CLI authenticates to the gateway with this token; the gateway injects
# the real subscription credential upstream. ANTHROPIC_API_KEY and
# CLAUDE_CODE_OAUTH_TOKEN are ignored/unset in this mode (they'd take precedence).
#   ANTHROPIC_BASE_URL=http://127.0.0.1:4000   (LiteLLM, surtr loopback)
#   ANTHROPIC_AUTH_TOKEN=sk-...                (LiteLLM virtual key)
# Aliases (sonnet/opus/haiku) resolve via these so the gateway gets concrete ids:
#   ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
#   ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-8
#   ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_AUTH_TOKEN=

# --- Cursor seat (Ratatoskr sidecar :8791) ---
# Sindri engine "cursor-api" talks here (Messages / OpenAI-compat). Prefer LiteLLM
# vkey via ANTHROPIC_* once cursor/* models are registered; until then point direct:
#   CURSOR_SEAT_URL=http://ratatoskr-cursor:8791   (compose) or http://127.0.0.1:8791
#   CURSOR_SEAT_INGRESS=<ingress key, never the seat credential>
# Cursor CLI engine needs agent on PATH + seat credential in the chat container:
#   CURSOR_API_KEY=crsr_…   (or CURSOR_AUTH_TOKEN=JWT from agent login)
CURSOR_SEAT_URL=
CURSOR_SEAT_INGRESS=
# CURSOR_API_KEY=
# CURSOR_AUTH_TOKEN=
# CURSOR_AGENT_BIN=agent

# --- Auth mode (per project default) ---
# subscription (default; lent Max seat via `claude setup-token`) | api_key (via the
# gateway — deferred multi-tenant/public path)
BROKK_AUTH_MODE=subscription

# --- Mímir (the counselor: triador + enhancer + planner) ---
# Provider: "claude" (default — reuses the Max seat via `claude -p`, routed
# through headroom; no extra key) or "openai". Auto-detects: claude if
# CLAUDE_CODE_OAUTH_TOKEN is set, else openai if MIMIR_API_KEY is set.
MIMIR_PROVIDER=claude
# Per-function model tiers. Planner is the high-leverage call → strong model;
# enhancer is cosmetic → cheap; triador in between. (claude: haiku|sonnet|opus)
MIMIR_PLANNER_MODEL=sonnet
MIMIR_TRIAGE_MODEL=sonnet
MIMIR_ENHANCE_MODEL=haiku
# CLAUDE_BIN=claude            # path to the claude CLI (default: on PATH)
# --- openai provider (legacy fallback) ---
MIMIR_MODEL=gpt-4.1-mini
MIMIR_BASE_URL=https://api.openai.com/v1
MIMIR_API_KEY=

# --- Dev-preview supervisor (runner) ---
# Hauldr control-plane URL. NOT a credential — the forge passes it to the preview
# so the APP can apply its OWN db/migrations with the per-project migrate token
# Heimdall hands back. Empty = previews run passthrough (no provisioning).
#
# There is deliberately NO HAULDR_TOKEN here anymore. That was the data plane's
# MANAGEMENT key: it read the superuser DSN of every project on the fleet, a
# client's production database included, so the forge could provision one dev
# lane. Lanes now come from Heimdall's scoped agent API, which serves only
# <app>_dev of a registered app. If you find yourself wanting the key back, you
# want a Heimdall route instead.
HAULDR_CONTROL_URL=

# --- Heimdall Agent API ---
# Three consumers, same pair:
#  - brokk-api: Nova Conversa (ADR 0038) — create / publish / versions / rollback,
#    and the Studio resolving a dev lane's db url
#  - forge: the dev lane's backend (POST /api/agent/lanes/<app>_dev)
#  - chat: Sindri's set_env / redeploy_app / register_route / register_job
# HEIMDALL_AGENT_URL is Heimdall's WEB base URL (the /api/agent/* proxies live
# there, NOT on the control-plane API); HEIMDALL_AGENT_TOKEN is the SCOPED token
# and must equal HEIMDALL_AGENT_TOKEN on the Heimdall web env. It is deliberately
# NOT the internal token: the lifecycle verbs are scoped to apps this agent
# created, so a compromised Brokk cannot publish over a client's production app.
# Unset = provisioning 503s and the infra tools report "not available".
#
# Prefer the INTERNAL name when both run on the same Docker network:
#   HEIMDALL_AGENT_URL=http://heimdall-web:3000
# Publish waits on cold prod-Hauldr provisioning (~300s) and Cloudflare cuts a
# proxied request at ~100s (524) — going out the public URL breaks Publish
# mid-birth, and silently. `heimdall-web` is the alias to use; plain `web` is
# generic and collides on the shared network.
HEIMDALL_AGENT_URL=http://heimdall-web:3000
HEIMDALL_AGENT_TOKEN=

# Preview boot command — OPTIONAL OPS OVERRIDE, leave EMPTY in normal operation.
# Sleipnir resolves the command per-repo from the pinned RuntimeSpec (Next/Vite/
# Astro, see docs/RUNTIME.md). Setting these forces EVERY preview to this command
# and DEFEATS per-repo detection — only set them to deliberately pin one stack.
# $PORT is substituted at runtime. BROKK_PREVIEW_DEV_CMD overrides dev (HMR) boots.
#
# BROKK-37 (densificação): Next 16+ defaults to Turbopack (~4GB RSS/app) — inviável
# with many concurrent previews. Sleipnir injects `next dev --webpack` for Next ≥16
# automatically (~1–1.5GB). Do NOT put `--turbo`/`--turbopack` in an override; for
# Next ≥16 include `--webpack` yourself if you must override. Operational ceiling
# per Next preview: ~1.5GB (webpack/SWC). The forge container mem_limit (4–6g in
# docker-compose.forge.yml) is the host budget for the runner + N live previews.
BROKK_PREVIEW_CMD=
BROKK_PREVIEW_DEV_CMD=
# Port range the supervisor allocates to preview processes [min, max].
# Default: 4100 – 4199
# Compact the transcript when a round reports this many input tokens
# (older rounds fold into a summary; 0 = off). Default: 120000
BROKK_COMPACT_INPUT_TOKENS=
# Cumulative token budget per chat turn (input+output; 0 = unlimited)
BROKK_TURN_TOKEN_BUDGET=

# Preview supervisor toggle for a forge runner (default on). Extra claim-only
# replicas (see forge-b in the Coolify compose) set 0 — exactly ONE runner may
# own the preview singleton per environment.
BROKK_SUPERVISOR=

# MCP servers mounted into Sindri turns (JSON array; ADR 0027 §4.1), e.g.
# [{"name":"hauldr","transport":"http","url":"https://…/mcp","headers":{"authorization":"Bearer …"}}]
# Tools are namespaced mcp__<server>__<tool>; read-only by default
# (annotations.readOnlyHint), allowTools/allowMutations per server to widen.
BROKK_MCP_SERVERS=

BROKK_PREVIEW_PORT_MIN=4100
BROKK_PREVIEW_PORT_MAX=4199

# --- Eitri security ward (vulnerability scanning) ---
# Run the OSS scanners (semgrep + trivy) over each PR's changed files before the
# LLM review. HIGH/CRITICAL findings deterministically force REQUEST_CHANGES.
# Install on the Eitri host: `pipx install semgrep` and the trivy binary
# (https://aquasecurity.github.io/trivy). Missing binaries are skipped gracefully.
# Default: on. Set to "false" to disable scanning entirely.
EITRI_SECURITY_SCAN=
# semgrep ruleset: a pinned pack like "p/default" / "p/security-audit" /
# "p/owasp-top-ten". Default: p/default. (Avoid "auto" — it needs metrics ON to
# resolve rules, which Eitri keeps off; pinned packs run with metrics disabled.)
EITRI_SEMGREP_CONFIG=
# Minimum severity (in changed files) that blocks the PR: critical|high|medium|low.
# Default: high
EITRI_SCAN_BLOCK_SEVERITY=
