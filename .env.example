# --- Brokk control plane ---
BROKK_DATABASE_URL=postgres://brokk:brokk@localhost:5432/brokk
BROKK_API_PORT=8789
# Internal API URL for the Next.js web app (Docker: http://api:8789).
BROKK_API_INTERNAL_URL=http://127.0.0.1:8789

# --- Production (Coolify docker-compose.prod.yml) ---
# POSTGRES_PASSWORD=          # brokk-db password (default: brokk)

# --- Runner ↔ control-plane ---
# Shared secret the runner presents on /runner/* endpoints.
BROKK_RUNNER_SECRET=
# Where the runner reaches the control plane (claim / events / complete).
BROKK_CONTROL_URL=http://localhost:8789

# --- GitHub (runner) ---
# Fine-grained token: contents + pull_requests write on target repos. Used by `gh`.
GITHUB_TOKEN=

# --- Claude Agent SDK (runner brain) ---
ANTHROPIC_API_KEY=
# Point the SDK at the headroom compression proxy (or the CCL AI gateway).
ANTHROPIC_BASE_URL=http://localhost:8787

# --- Auth mode (per project default) ---
# api_key (default; via the gateway) | subscription (claude setup-token)
BROKK_AUTH_MODE=api_key

# --- Mímir (the counselor: triador + enhancer) ---
# One cheap model runs both the triador (two-axis router) and the enhancer.
MIMIR_MODEL=gpt-4.1-mini
# OpenAI-compatible endpoint — point at the CCL AI gateway or OpenAI directly.
MIMIR_BASE_URL=https://api.openai.com/v1
MIMIR_API_KEY=
